{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "audio",
  "description": "Allows invoking OS-native text-to-speech commands",
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "say-tts",
          "cmd": "say",
          "args": ["-v", "Kyoko", { "validator": "^[^;&|`$]*$" }],
          "sidecar": false
        },
        {
          "name": "powershell-tts",
          "cmd": "powershell",
          "args": [
            "-NoProfile",
            "-Command",
            { "validator": "^[^;&|`]*$" }
          ],
          "sidecar": false
        }
      ]
    }
  ]
}
